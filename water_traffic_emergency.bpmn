    <bpmn:sequenceFlow id="Flow_IssueOrders_Split" sourceRef="Task_IssueOrders" targetRef="Gateway_ParallelSplit" />
    <bpmn:sequenceFlow id="Flow_Split_Medical" sourceRef="Gateway_ParallelSplit" targetRef="Task_MedicalAid" />
    <bpmn:sequenceFlow id="Flow_Split_Engineering" sourceRef="Gateway_ParallelSplit" targetRef="Task_EngineeringControl" />
    <bpmn:sequenceFlow id="Flow_Split_Evacuation" sourceRef="Gateway_ParallelSplit" targetRef="Task_Evacuation" />
    <bpmn:sequenceFlow id="Flow_Split_Communications" sourceRef="Gateway_ParallelSplit" targetRef="Task_Communications" />
    <bpmn:sequenceFlow id="Flow_Medical_Join" sourceRef="Task_MedicalAid" targetRef="Gateway_ParallelJoin" />
    <bpmn:sequenceFlow id="Flow_Engineering_Join" sourceRef="Task_EngineeringControl" targetRef="Gateway_ParallelJoin" />
    <bpmn:sequenceFlow id="Flow_Evacuation_Join" sourceRef="Task_Evacuation" targetRef="Gateway_ParallelJoin" />
    <bpmn:sequenceFlow id="Flow_Communications_Join" sourceRef="Task_Communications" targetRef="Gateway_ParallelJoin" />
