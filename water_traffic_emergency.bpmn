  <bpmn:process id="Process_ExternalSupport" name="外部支援协同" isExecutable="false">
    <bpmn:startEvent id="StartEvent_ExternalAlert" name="接收通报">
      <bpmn:outgoing>Flow_ExternalStart_Receive</bpmn:outgoing>
      <bpmn:documentation>政府及专业机构接到事故报告，启动协同程序。</bpmn:documentation>
    </bpmn:startEvent>
    <bpmn:task id="Task_ReceiveReport" name="确认事故信息">
      <bpmn:incoming>Flow_ExternalStart_Receive</bpmn:incoming>
      <bpmn:outgoing>Flow_ExternalReceive_Support</bpmn:outgoing>
      <bpmn:documentation>主管部门核实通报内容并登记险情要素。</bpmn:documentation>
    </bpmn:task>
    <bpmn:task id="Task_ProvideGuidance" name="提供指挥支援">
      <bpmn:incoming>Flow_ExternalReceive_Support</bpmn:incoming>
      <bpmn:outgoing>Flow_ExternalSupport_End</bpmn:outgoing>
      <bpmn:documentation>根据项目请求调配外部力量并反馈处置指令。</bpmn:documentation>
    </bpmn:task>
    <bpmn:endEvent id="EndEvent_ExternalComplete" name="协同结束">
      <bpmn:incoming>Flow_ExternalSupport_End</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_ExternalStart_Receive" sourceRef="StartEvent_ExternalAlert" targetRef="Task_ReceiveReport" />
    <bpmn:sequenceFlow id="Flow_ExternalReceive_Support" sourceRef="Task_ReceiveReport" targetRef="Task_ProvideGuidance" />
    <bpmn:sequenceFlow id="Flow_ExternalSupport_End" sourceRef="Task_ProvideGuidance" targetRef="EndEvent_ExternalComplete" />
  </bpmn:process>
