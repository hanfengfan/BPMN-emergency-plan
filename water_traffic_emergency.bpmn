    </bpmn:laneSet>
    <bpmn:startEvent id="StartEvent_WaterIncident" name="事故发现/预警">
      <bpmn:outgoing>Flow_1</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:task id="Activity_1" name="事故预警">
      <bpmn:incoming>Flow_1</bpmn:incoming>
      <bpmn:outgoing>Flow_2</bpmn:outgoing>
      <bpmn:documentation>层级：1
任务描述：识别风险、发布预警、调整施工
责任主体：综合协调组、技术支持组
所需资源：监测信息、预警系统
任务路径：总体应急目标 → 事故预警</bpmn:documentation>
    </bpmn:task>
    <bpmn:task id="Activity_2" name="风险监测">
      <bpmn:incoming>Flow_2</bpmn:incoming>
      <bpmn:outgoing>Flow_3</bpmn:outgoing>
      <bpmn:documentation>层级：2
任务描述：风险辨识与监控
责任主体：技术支持组
所需资源：风险评估工具
任务路径：总体应急目标 → 事故预警 → 风险监测</bpmn:documentation>
    </bpmn:task>
    <bpmn:task id="Activity_3" name="日常巡查">
      <bpmn:incoming>Flow_3</bpmn:incoming>
      <bpmn:outgoing>Flow_4</bpmn:outgoing>
      <bpmn:documentation>层级：3
任务描述：定期检查施工设备、船舶状况
责任主体：技术支持组
所需资源：检查表、监测仪器
任务路径：总体应急目标 → 事故预警 → 风险监测 → 日常巡查</bpmn:documentation>
    </bpmn:task>
    <bpmn:task id="Activity_4" name="环境监测">
      <bpmn:incoming>Flow_4</bpmn:incoming>
      <bpmn:outgoing>Flow_5</bpmn:outgoing>
      <bpmn:documentation>层级：3
任务描述：监控风力、潮汐、能见度等气象条件
责任主体：技术支持组
所需资源：气象信息系统
任务路径：总体应急目标 → 事故预警 → 风险监测 → 环境监测</bpmn:documentation>
    </bpmn:task>
    <bpmn:task id="Activity_5" name="预警发布">
      <bpmn:incoming>Flow_5</bpmn:incoming>
      <bpmn:outgoing>Flow_6</bpmn:outgoing>
      <bpmn:documentation>层级：2
任务描述：分级发布蓝/黄/橙/红预警
责任主体：项目部应急办公室
所需资源：预警信息通告
任务路径：总体应急目标 → 事故预警 → 预警发布</bpmn:documentation>
    </bpmn:task>
    <bpmn:task id="Activity_6" name="信息通报">
      <bpmn:incoming>Flow_6</bpmn:incoming>
      <bpmn:outgoing>Flow_7</bpmn:outgoing>
      <bpmn:documentation>层级：3
任务描述：发布预警通知至各小组
责任主体：综合协调组
所需资源：预警通知单
任务路径：总体应急目标 → 事故预警 → 预警发布 → 信息通报</bpmn:documentation>
    </bpmn:task>
    <bpmn:task id="Activity_7" name="事故报告">
      <bpmn:incoming>Flow_7</bpmn:incoming>
      <bpmn:outgoing>Flow_8</bpmn:outgoing>
      <bpmn:documentation>层级：1
任务描述：发现事故、逐级报告、上报政府
预案摘录：#### 2.2.5 应急处置措施…
责任主体：信息联络组、现场处置小组
所需资源：通讯工具、报告模板
任务路径：总体应急目标 → 事故报告</bpmn:documentation>
    </bpmn:task>
    <bpmn:task id="Activity_8" name="事故发现">
      <bpmn:incoming>Flow_8</bpmn:incoming>
      <bpmn:outgoing>Flow_9</bpmn:outgoing>
      <bpmn:documentation>层级：2
任务描述：现场人员立即上报
责任主体：现场处置小组
所需资源：通讯工具
任务路径：总体应急目标 → 事故报告 → 事故发现</bpmn:documentation>
    </bpmn:task>
    <bpmn:task id="Activity_9" name="报告内容确认">
      <bpmn:incoming>Flow_9</bpmn:incoming>
      <bpmn:outgoing>Flow_10</bpmn:outgoing>
      <bpmn:documentation>层级：3
任务描述：报告事故时间、地点、人员伤亡
责任主体：现场处置小组
所需资源：通讯工具
任务路径：总体应急目标 → 事故报告 → 事故发现 → 报告内容确认</bpmn:documentation>
    </bpmn:task>
    <bpmn:task id="Activity_10" name="信息汇总">
      <bpmn:incoming>Flow_10</bpmn:incoming>
      <bpmn:outgoing>Flow_11</bpmn:outgoing>
      <bpmn:documentation>层级：2
任务描述：项目部应急办公室汇总情况
责任主体：信息联络组
所需资源：事故信息表
任务路径：总体应急目标 → 事故报告 → 信息汇总</bpmn:documentation>
    </bpmn:task>
    <bpmn:task id="Activity_11" name="核实信息">
      <bpmn:incoming>Flow_11</bpmn:incoming>
      <bpmn:outgoing>Flow_12</bpmn:outgoing>
      <bpmn:documentation>层级：3
任务描述：对接监理和建设单位确认信息
责任主体：信息联络组
所需资源：事故信息表
任务路径：总体应急目标 → 事故报告 → 信息汇总 → 核实信息</bpmn:documentation>
    </bpmn:task>
    <bpmn:task id="Activity_12" name="上报政府">
      <bpmn:incoming>Flow_12</bpmn:incoming>
      <bpmn:outgoing>Flow_13</bpmn:outgoing>
      <bpmn:documentation>层级：2
任务描述：逐级上报交通局、应急局、海事局
责任主体：信息联络组
所需资源：联系方式清单
任务路径：总体应急目标 → 事故报告 → 上报政府</bpmn:documentation>
    </bpmn:task>
    <bpmn:task id="Activity_13" name="逐级汇报">
      <bpmn:incoming>Flow_13</bpmn:incoming>
      <bpmn:outgoing>Flow_14</bpmn:outgoing>
      <bpmn:documentation>层级：3
任务描述：按要求向交通、应急、海事局上报
责任主体：信息联络组
所需资源：联系方式清单
任务路径：总体应急目标 → 事故报告 → 上报政府 → 逐级汇报</bpmn:documentation>
    </bpmn:task>
    <bpmn:task id="Activity_14" name="应急响应">
      <bpmn:incoming>Flow_14</bpmn:incoming>
      <bpmn:outgoing>Flow_15</bpmn:outgoing>
      <bpmn:documentation>层级：1
任务描述：启动预案、组织队伍、调配资源
预案摘录：#### 2.2.4 处置程序 发生险情时，现场处置小组立即开展先期应急处置工作，同时上报项目部应急救援领导小组，项目部应急救援领导小组获取事故的险情报告后，立即对险情进行评估，根据险情评估结果确定响应等级并启动预案。 其中，应急响应、后期处置等，详见第一章总则1.6、1.7。 具体现场处置流程如下：…
责任主体：项目部应急领导小组
所需资源：应急车辆、通信装备
任务路径：总体应急目标 → 应急响应</bpmn:documentation>
    </bpmn:task>
    <bpmn:task id="Activity_15" name="分级响应">
      <bpmn:incoming>Flow_15</bpmn:incoming>
      <bpmn:outgoing>Flow_16</bpmn:outgoing>
      <bpmn:documentation>层级：2
任务描述：根据严重程度启动Ⅰ级或Ⅱ级
责任主体：项目部应急领导小组
所需资源：响应分级标准
任务路径：总体应急目标 → 应急响应 → 分级响应</bpmn:documentation>
    </bpmn:task>
    <bpmn:task id="Activity_16" name="启动Ⅱ级响应">
      <bpmn:incoming>Flow_16</bpmn:incoming>
      <bpmn:outgoing>Flow_17</bpmn:outgoing>
      <bpmn:documentation>层级：3
任务描述：项目内部组织自救
责任主体：项目部应急领导小组
所需资源：项目部资源
任务路径：总体应急目标 → 应急响应 → 分级响应 → 启动Ⅱ级响应</bpmn:documentation>
    </bpmn:task>
    <bpmn:task id="Activity_17" name="启动Ⅰ级响应">
      <bpmn:incoming>Flow_17</bpmn:incoming>
      <bpmn:outgoing>Flow_18</bpmn:outgoing>
      <bpmn:documentation>层级：3
任务描述：请求社会力量支援
责任主体：项目部应急领导小组
所需资源：政府应急资源
任务路径：总体应急目标 → 应急响应 → 分级响应 → 启动Ⅰ级响应</bpmn:documentation>
    </bpmn:task>
    <bpmn:task id="Activity_18" name="任务分工">
      <bpmn:incoming>Flow_18</bpmn:incoming>
      <bpmn:outgoing>Flow_19</bpmn:outgoing>
      <bpmn:documentation>层级：2
任务描述：各小组按职责执行
责任主体：工程抢险组、医疗救护组
所需资源：救援任务单
任务路径：总体应急目标 → 应急响应 → 任务分工</bpmn:documentation>
    </bpmn:task>
    <bpmn:task id="Activity_19" name="下达指令">
      <bpmn:incoming>Flow_19</bpmn:incoming>
      <bpmn:outgoing>Flow_20</bpmn:outgoing>
      <bpmn:documentation>层级：3
任务描述：组长向各小组明确任务
责任主体：项目部领导
所需资源：任务分工表
任务路径：总体应急目标 → 应急响应 → 任务分工 → 下达指令</bpmn:documentation>
    </bpmn:task>
    <bpmn:task id="Activity_20" name="现场处置">
      <bpmn:incoming>Flow_20</bpmn:incoming>
      <bpmn:outgoing>Flow_21</bpmn:outgoing>
      <bpmn:documentation>层级：1
任务描述：实施救援、控制险情、人员疏散
预案摘录：#### 2.2.4 处置程序 发生险情时，现场处置小组立即开展先期应急处置工作，同时上报项目部应急救援领导小组，项目部应急救援领导小组获取事故的险情报告后，立即对险情进行评估，根据险情评估结果确定响应等级并启动预案。 其中，应急响应、后期处置等，详见第一章总则1.6、1.7。 具体现场处置流程如下：…
责任主体：工程抢险组、医疗救护组、综合协调组
所需资源：抢险设备、医疗物资、交通管制设施
任务路径：总体应急目标 → 现场处置</bpmn:documentation>
    </bpmn:task>
    <bpmn:task id="Activity_21" name="人员救护">
      <bpmn:incoming>Flow_21</bpmn:incoming>
      <bpmn:outgoing>Flow_22</bpmn:outgoing>
      <bpmn:documentation>层级：2
任务描述：现场急救、转运医院
责任主体：医疗救护组
所需资源：急救药品、担架、救护车
任务路径：总体应急目标 → 现场处置 → 人员救护</bpmn:documentation>
    </bpmn:task>
    <bpmn:task id="Activity_22" name="现场急救">
      <bpmn:incoming>Flow_22</bpmn:incoming>
      <bpmn:outgoing>Flow_23</bpmn:outgoing>
      <bpmn:documentation>层级：3
任务描述：止血、包扎、心肺复苏
责任主体：医疗救护组
所需资源：急救药品、担架
任务路径：总体应急目标 → 现场处置 → 人员救护 → 现场急救</bpmn:documentation>
    </bpmn:task>
    <bpmn:task id="Activity_23" name="医院转运">
      <bpmn:incoming>Flow_23</bpmn:incoming>
      <bpmn:outgoing>Flow_24</bpmn:outgoing>
      <bpmn:documentation>层级：3
任务描述：联系120并护送伤员
责任主体：医疗救护组
所需资源：救护车、转运路线
任务路径：总体应急目标 → 现场处置 → 人员救护 → 医院转运</bpmn:documentation>
    </bpmn:task>
    <bpmn:task id="Activity_24" name="工程抢险">
      <bpmn:incoming>Flow_24</bpmn:incoming>
      <bpmn:outgoing>Flow_25</bpmn:outgoing>
      <bpmn:documentation>层级：2
任务描述：设备抢险、险情控制
责任主体：工程抢险组
所需资源：排水泵、堵漏工具、吊装设备
任务路径：总体应急目标 → 现场处置 → 工程抢险</bpmn:documentation>
    </bpmn:task>
    <bpmn:task id="Activity_25" name="封锁险区">
      <bpmn:incoming>Flow_25</bpmn:incoming>
      <bpmn:outgoing>Flow_26</bpmn:outgoing>
      <bpmn:documentation>层级：3
任务描述：设立警戒线，禁止无关人员进入
责任主体：工程抢险组
所需资源：警示标志、围栏
任务路径：总体应急目标 → 现场处置 → 工程抢险 → 封锁险区</bpmn:documentation>
    </bpmn:task>
    <bpmn:task id="Activity_26" name="险情控制">
      <bpmn:incoming>Flow_26</bpmn:incoming>
      <bpmn:outgoing>Flow_27</bpmn:outgoing>
      <bpmn:documentation>层级：3
任务描述：排水、堵漏、加固等措施
责任主体：工程抢险组
所需资源：抢险设备
任务路径：总体应急目标 → 现场处置 → 工程抢险 → 险情控制</bpmn:documentation>
    </bpmn:task>
    <bpmn:task id="Activity_27" name="综合协调">
      <bpmn:incoming>Flow_27</bpmn:incoming>
      <bpmn:outgoing>Flow_28</bpmn:outgoing>
      <bpmn:documentation>层级：2
任务描述：交通管制、人员疏散、现场保护
责任主体：综合协调组
所需资源：警示标志、交通管制设施
任务路径：总体应急目标 → 现场处置 → 综合协调</bpmn:documentation>
    </bpmn:task>
    <bpmn:task id="Activity_28" name="疏散人员">
      <bpmn:incoming>Flow_28</bpmn:incoming>
      <bpmn:outgoing>Flow_29</bpmn:outgoing>
      <bpmn:documentation>层级：3
任务描述：组织施工人员撤离危险区
责任主体：综合协调组
所需资源：交通管制设施
任务路径：总体应急目标 → 现场处置 → 综合协调 → 疏散人员</bpmn:documentation>
    </bpmn:task>
    <bpmn:task id="Activity_29" name="信息联络">
      <bpmn:incoming>Flow_29</bpmn:incoming>
      <bpmn:outgoing>Flow_30</bpmn:outgoing>
      <bpmn:documentation>层级：2
任务描述：对内传达、对外联络
责任主体：信息联络组
所需资源：通信装备
任务路径：总体应急目标 → 现场处置 → 信息联络</bpmn:documentation>
    </bpmn:task>
    <bpmn:task id="Activity_30" name="外部联络">
      <bpmn:incoming>Flow_30</bpmn:incoming>
      <bpmn:outgoing>Flow_31</bpmn:outgoing>
      <bpmn:documentation>层级：3
任务描述：联系医院、政府部门
责任主体：信息联络组
所需资源：通讯设备
任务路径：总体应急目标 → 现场处置 → 信息联络 → 外部联络</bpmn:documentation>
    </bpmn:task>
    <bpmn:task id="Activity_31" name="后期恢复">
      <bpmn:incoming>Flow_31</bpmn:incoming>
      <bpmn:outgoing>Flow_32</bpmn:outgoing>
      <bpmn:documentation>层级：1
任务描述：事故调查、善后处置、总结评估
责任主体：善后处置组、技术支持组
所需资源：法律支持、补偿资金、评估报告
任务路径：总体应急目标 → 后期恢复</bpmn:documentation>
    </bpmn:task>
    <bpmn:task id="Activity_32" name="善后工作">
      <bpmn:incoming>Flow_32</bpmn:incoming>
      <bpmn:outgoing>Flow_33</bpmn:outgoing>
      <bpmn:documentation>层级：2
任务描述：人员安置、补偿、心理安抚
责任主体：善后处置组
所需资源：补偿资金、安置方案
任务路径：总体应急目标 → 后期恢复 → 善后工作</bpmn:documentation>
    </bpmn:task>
    <bpmn:task id="Activity_33" name="心理安抚">
      <bpmn:incoming>Flow_33</bpmn:incoming>
      <bpmn:outgoing>Flow_34</bpmn:outgoing>
      <bpmn:documentation>层级：3
任务描述：对伤亡人员家属进行安抚
责任主体：善后处置组
所需资源：心理辅导人员
任务路径：总体应急目标 → 后期恢复 → 善后工作 → 心理安抚</bpmn:documentation>
    </bpmn:task>
    <bpmn:task id="Activity_34" name="事故调查">
      <bpmn:incoming>Flow_34</bpmn:incoming>
      <bpmn:outgoing>Flow_35</bpmn:outgoing>
      <bpmn:documentation>层级：2
任务描述：事故原因调查、责任认定
责任主体：技术支持组、外部机构
所需资源：调查报告、法律文件
任务路径：总体应急目标 → 后期恢复 → 事故调查</bpmn:documentation>
    </bpmn:task>
    <bpmn:task id="Activity_35" name="资料收集">
      <bpmn:incoming>Flow_35</bpmn:incoming>
      <bpmn:outgoing>Flow_36</bpmn:outgoing>
      <bpmn:documentation>层级：3
任务描述：收集事故记录、日志、证据
责任主体：技术支持组
所需资源：调查工具
任务路径：总体应急目标 → 后期恢复 → 事故调查 → 资料收集</bpmn:documentation>
    </bpmn:task>
    <bpmn:task id="Activity_36" name="总结评估">
      <bpmn:incoming>Flow_36</bpmn:incoming>
      <bpmn:outgoing>Flow_37</bpmn:outgoing>
      <bpmn:documentation>层级：2
任务描述：应急响应效果评估
责任主体：项目部应急领导小组
所需资源：评估报告
任务路径：总体应急目标 → 后期恢复 → 总结评估</bpmn:documentation>
    </bpmn:task>
    <bpmn:task id="Activity_37" name="编写报告">
