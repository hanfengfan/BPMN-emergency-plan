    <bpmn:sequenceFlow id="Flow_Gateway_External" sourceRef="Gateway_ResponseLevel" targetRef="Task_RequestExternalSupport" name="需外部支援" />
    <bpmn:sequenceFlow id="Flow_Internal_Merge" sourceRef="Task_InternalResponse" targetRef="Gateway_ResponseMerge" />
    <bpmn:sequenceFlow id="Flow_External_Merge" sourceRef="Task_RequestExternalSupport" targetRef="Gateway_ResponseMerge" />
