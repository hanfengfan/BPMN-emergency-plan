<?xml version='1.0' encoding='utf-8'?>
<bpmn:definitions id="Definitions_WaterTrafficEmergency" targetNamespace="http://example.com/bpmn/water-traffic-emergency">
  <bpmn:collaboration id="Collaboration_WaterTrafficEmergency">
    <bpmn:participant id="Participant_Project" name="项目部应急组织" processRef="Process_WaterTrafficEmergency" />
    <bpmn:participant id="Participant_External" name="政府及外部支援机构" processRef="Process_ExternalSupport" />
    <bpmn:messageFlow id="MessageFlow_GovernmentReport" name="事故报告" sourceRef="Task_EscalateAuthorities" targetRef="Task_ReceiveReport" />
    <bpmn:messageFlow id="MessageFlow_SupportRequest" name="支援请求" sourceRef="Task_RequestExternalSupport" targetRef="Task_ProvideGuidance" />
    <bpmn:messageFlow id="MessageFlow_StatusUpdate" name="现场动态" sourceRef="Task_ExternalLiaison" targetRef="Task_ProvideGuidance" />
  </bpmn:collaboration>
  <bpmn:process id="Process_WaterTrafficEmergency" name="水上交通事故应急流程" isExecutable="false">
    <bpmn:laneSet id="LaneSet_Project">
      <bpmn:lane id="Lane_1" name="技术支持组">
        <bpmn:flowNodeRef>StartEvent_RoutineMonitoring</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_PreventiveWatch</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_RiskPatrol</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_PreventiveSplit</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_InspectEquipment</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_MonitorEnvironment</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_PreventiveJoin</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_Investigation</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_CollectEvidence</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_2" name="信息联络组">
        <bpmn:flowNodeRef>Task_PublishAlert</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_SummariseSituation</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_VerifyWithUnits</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ReportAuthorities</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_EscalateAuthorities</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_Communications</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ExternalLiaison</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_3" name="综合协调组">
        <bpmn:flowNodeRef>Task_NotifyTeams</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_Coordination</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_Evacuation</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_4" name="现场处置小组">
        <bpmn:flowNodeRef>IntermediateEvent_Incident</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ReportProcess</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ReportIncident</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ConfirmDetails</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_5" name="项目部应急领导小组">
        <bpmn:flowNodeRef>Task_InitiateResponse</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_AssessResponseLevel</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_ResponseLevel</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_InternalResponse</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_RequestExternalSupport</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_ResponseMerge</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_DefineTeamMissions</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_RecoveryTransition</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_RecoverySplit</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_RecoveryMerge</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_EvaluateResponse</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_FinalReport</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_ResponseComplete</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_6" name="项目部领导">
        <bpmn:flowNodeRef>Task_IssueOrders</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_OnsiteOperations</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_ParallelSplit</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_ParallelJoin</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_7" name="工程抢险组">
        <bpmn:flowNodeRef>Task_EngineeringDeploy</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_BlockArea</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_EngineeringControl</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_8" name="医疗救护组">
        <bpmn:flowNodeRef>Task_MedicalPlan</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_MedicalAid</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_MedicalTransfer</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_9" name="善后处置组">
        <bpmn:flowNodeRef>Task_Aftercare</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_PsychologicalSupport</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:dataObject id="Data_IncidentReport" name="险情快报" />
    <bpmn:dataObjectReference id="DataRef_IncidentReport" dataObjectRef="Data_IncidentReport" name="险情快报" />
    <bpmn:dataObject id="Data_ResponseOrders" name="响应指令" />
    <bpmn:dataObjectReference id="DataRef_ResponseOrders" dataObjectRef="Data_ResponseOrders" name="响应指令" />
    <bpmn:dataObject id="Data_MedicalRecord" name="医疗救护记录" />
    <bpmn:dataObjectReference id="DataRef_MedicalRecord" dataObjectRef="Data_MedicalRecord" name="医疗救护记录" />
    <bpmn:dataObject id="Data_EngineeringLog" name="工程抢险记录" />
    <bpmn:dataObjectReference id="DataRef_EngineeringLog" dataObjectRef="Data_EngineeringLog" name="工程抢险记录" />
    <bpmn:dataObject id="Data_StatusUpdates" name="现场联络日志" />
    <bpmn:dataObjectReference id="DataRef_StatusUpdates" dataObjectRef="Data_StatusUpdates" name="现场联络日志" />
    <bpmn:dataObject id="Data_FinalReport" name="事故总结报告" />
    <bpmn:dataObjectReference id="DataRef_FinalReport" dataObjectRef="Data_FinalReport" name="事故总结报告" />
    <bpmn:startEvent id="StartEvent_RoutineMonitoring" name="常态监测">
      <bpmn:outgoing>Flow_Start_Preventive</bpmn:outgoing>
      <bpmn:documentation>技术支持组开展航道施工常态巡查与风险监测的起点。</bpmn:documentation>
    </bpmn:startEvent>
    <bpmn:task id="Task_PreventiveWatch" name="监测施工水域风险并预警">
      <bpmn:incoming>Flow_Start_Preventive</bpmn:incoming>
      <bpmn:outgoing>Flow_Preventive_RiskPatrol</bpmn:outgoing>
      <bpmn:documentation>层级：1
任务描述：综合协调组联合技术支持组围绕船员、船舶与环境因素评估碰撞、火灾、风浪、自沉等风险，提前调整施工计划并准备应对措施。
预案摘录：预案2.2.2指出水上作业可能因船员因素、船舶因素和环境因素引发碰撞、火灾、风灾、自沉、搁浅等事故，需要提前识别风险并采取预警措施。
责任主体：综合协调组、技术支持组
所需资源：监测信息、预警系统、风险评估工具
任务路径：总体应急目标 → 监测施工水域风险并预警</bpmn:documentation>
    </bpmn:task>
    <bpmn:task id="Task_RiskPatrol" name="巡查施工与航道风险点">
      <bpmn:incoming>Flow_Preventive_RiskPatrol</bpmn:incoming>
      <bpmn:outgoing>Flow_RiskPatrol_Split</bpmn:outgoing>
      <bpmn:documentation>层级：2
任务描述：技术支持组对施工海域的船舶运行、作业干扰和周边航行环境实施巡查，跟踪可能诱发水上交通事故的风险点。
预案摘录：预案2.2.2(1)-(7)列举了船舶碰撞、火灾爆炸、风浪损伤、自沉、搁浅及人员落水等风险情形，要求持续监测施工与航道状况。
责任主体：技术支持组
所需资源：巡查计划、监测仪器
任务路径：总体应急目标 → 监测施工水域风险并预警 → 巡查施工与航道风险点</bpmn:documentation>
    </bpmn:task>
    <bpmn:parallelGateway id="Gateway_PreventiveSplit" name="风险监测分工">
      <bpmn:incoming>Flow_RiskPatrol_Split</bpmn:incoming>
      <bpmn:outgoing>Flow_Split_Inspect</bpmn:outgoing>
      <bpmn:outgoing>Flow_Split_Environment</bpmn:outgoing>
    </bpmn:parallelGateway>
    <bpmn:task id="Task_InspectEquipment" name="检查船舶与设备状态">
      <bpmn:incoming>Flow_Split_Inspect</bpmn:incoming>
      <bpmn:outgoing>Flow_Inspect_Join</bpmn:outgoing>
      <bpmn:documentation>层级：3
任务描述：落实船舶机舱、泵舱、消防、通信等设备的例行检查，发现设备异常及时调整，避免因设备缺陷诱发事故。
预案摘录：预案2.2.2强调船舶因素可能引发火灾、爆炸、自沉等险情，需要通过日常巡查掌握设备运行状态。
责任主体：技术支持组
所需资源：检查表、维护工具
任务路径：总体应急目标 → 监测施工水域风险并预警 → 巡查施工与航道风险点 → 检查船舶与设备状态</bpmn:documentation>
    </bpmn:task>
    <bpmn:task id="Task_MonitorEnvironment" name="掌握气象与水文条件">
      <bpmn:incoming>Flow_Split_Environment</bpmn:incoming>
      <bpmn:outgoing>Flow_Environment_Join</bpmn:outgoing>
      <bpmn:documentation>层级：3
任务描述：跟踪风力、突风、潮差和能见度等环境条件，及时采取避险或调整航行安排，降低风灾和浪损风险。
预案摘录：预案2.2.2(4)提示海上施工易受大风、突风影响发生风灾、浪损事故，需要加强环境监测。
责任主体：技术支持组
所需资源：气象信息系统、水文监测数据
任务路径：总体应急目标 → 监测施工水域风险并预警 → 巡查施工与航道风险点 → 掌握气象与水文条件</bpmn:documentation>
    </bpmn:task>
    <bpmn:parallelGateway id="Gateway_PreventiveJoin" name="监测信息汇总">
      <bpmn:incoming>Flow_Inspect_Join</bpmn:incoming>
      <bpmn:incoming>Flow_Environment_Join</bpmn:incoming>
      <bpmn:outgoing>Flow_PreventiveJoin_Publish</bpmn:outgoing>
    </bpmn:parallelGateway>
    <bpmn:task id="Task_PublishAlert" name="发布预警等级与调整施工">
      <bpmn:incoming>Flow_PreventiveJoin_Publish</bpmn:incoming>
      <bpmn:outgoing>Flow_Publish_Notify</bpmn:outgoing>
      <bpmn:documentation>层级：2
任务描述：项目部应急办公室依据风险巡查结果划分蓝、黄、橙、红预警等级，通知相关单位调整作业强度并做好防范部署。
预案摘录：预案要求根据监测到的碰撞、火灾、自沉等风险提前发布预警信息，引导施工单位采取防范措施。
责任主体：项目部应急办公室
所需资源：预警信息通告、调度指令
任务路径：总体应急目标 → 监测施工水域风险并预警 → 发布预警等级与调整施工</bpmn:documentation>
    </bpmn:task>
    <bpmn:task id="Task_NotifyTeams" name="通知各小组执行预警措施">
      <bpmn:incoming>Flow_Publish_Notify</bpmn:incoming>
      <bpmn:outgoing>Flow_Notify_Incident</bpmn:outgoing>
      <bpmn:documentation>层级：3
任务描述：综合协调组向各应急小组通报预警等级，明确值守、避风、减载、调整航次等协同动作。
预案摘录：预案2.2.2和2.2.5要求各小组分工明确、责任到人，接到预警后及时落实防控措施。
责任主体：综合协调组
所需资源：预警通知单、值班安排
任务路径：总体应急目标 → 监测施工水域风险并预警 → 发布预警等级与调整施工 → 通知各小组执行预警措施</bpmn:documentation>
    </bpmn:task>
    <bpmn:intermediateCatchEvent id="IntermediateEvent_Incident" name="事故发生">
      <bpmn:incoming>Flow_Notify_Incident</bpmn:incoming>
      <bpmn:outgoing>Flow_Incident_ReportProcess</bpmn:outgoing>
      <bpmn:documentation>施工现场突发水上交通事故，触发应急程序。</bpmn:documentation>
    </bpmn:intermediateCatchEvent>
    <bpmn:task id="Task_ReportProcess" name="事故信息上报启动流程">
      <bpmn:incoming>Flow_Incident_ReportProcess</bpmn:incoming>
      <bpmn:outgoing>Flow_ReportProcess_ReportIncident</bpmn:outgoing>
      <bpmn:documentation>层级：1
任务描述：信息联络组依照专项预案接收现场险情并向项目部、公司和政府主管部门逐级报告，为启动响应做准备。
预案摘录：预案2.2.4规定现场处置小组先期处置同时上报项目部，应急领导小组据此评估险情并决定响应等级。
责任主体：信息联络组、现场处置小组
所需资源：通讯工具、报告模板、联络清单
任务路径：总体应急目标 → 事故信息上报启动流程</bpmn:documentation>
    </bpmn:task>
    <bpmn:task id="Task_ReportIncident" name="现场人员立即报告险情">
      <bpmn:incoming>Flow_ReportProcess_ReportIncident</bpmn:incoming>
      <bpmn:outgoing>Flow_Report_Confirm</bpmn:outgoing>
      <bpmn:documentation>层级：2
任务描述：现场处置小组成员发现事故后第一时间通过通讯设备向项目部报告，说明地点、时间、伤亡及设备受损情况。
预案摘录：预案2.2.4(1)明确要求发现人员立即报告，阐明事故地点、时间、设备受损程度和受伤人数。
责任主体：现场处置小组
所需资源：通讯工具、现场记录
任务路径：总体应急目标 → 事故信息上报启动流程 → 现场人员立即报告险情</bpmn:documentation>
      <bpmn:ioSpecification>
        <bpmn:dataOutput id="Task_ReportIncident_Output_1" />
        <bpmn:outputSet>
          <bpmn:dataOutputRefs>Task_ReportIncident_Output_1</bpmn:dataOutputRefs>
        </bpmn:outputSet>
      </bpmn:ioSpecification>
      <bpmn:dataOutputAssociation id="DataAssoc_ReportIncident_Output">
        <bpmn:sourceRef>Task_ReportIncident_Output_1</bpmn:sourceRef>
        <bpmn:targetRef>DataRef_IncidentReport</bpmn:targetRef>
      </bpmn:dataOutputAssociation>
    </bpmn:task>
    <bpmn:task id="Task_ConfirmDetails" name="明确位置时间损失情况">
      <bpmn:incoming>Flow_Report_Confirm</bpmn:incoming>
      <bpmn:outgoing>Flow_Confirm_Summarise</bpmn:outgoing>
      <bpmn:documentation>层级：3
任务描述：在汇报中逐项核实事故发生位置、具体时间、设备损坏及伤亡情况，确保上报信息完整准确。
预案摘录：预案2.2.4(1)要求报告时准确说明事故地点、时间、设备受损程度和人员受伤情况。
责任主体：现场处置小组
所需资源：信息采集表、影像资料
任务路径：总体应急目标 → 事故信息上报启动流程 → 现场人员立即报告险情 → 明确位置时间损失情况</bpmn:documentation>
    </bpmn:task>
    <bpmn:task id="Task_SummariseSituation" name="项目部汇总并评估险情">
      <bpmn:incoming>Flow_Confirm_Summarise</bpmn:incoming>
      <bpmn:outgoing>Flow_Summarise_Verify</bpmn:outgoing>
      <bpmn:documentation>层级：2
任务描述：信息联络组汇集现场反馈与监测数据，研判事故发展态势，为应急领导小组决策提供依据。
预案摘录：预案2.2.4指出项目部应急救援领导小组接收险情报告后要立即评估并确定响应等级。
责任主体：信息联络组
所需资源：事故信息表、研判模型
任务路径：总体应急目标 → 事故信息上报启动流程 → 项目部汇总并评估险情</bpmn:documentation>
      <bpmn:ioSpecification>
        <bpmn:dataInput id="Task_SummariseSituation_Input_1" />
        <bpmn:inputSet>
          <bpmn:dataInputRefs>Task_SummariseSituation_Input_1</bpmn:dataInputRefs>
        </bpmn:inputSet>
      </bpmn:ioSpecification>
      <bpmn:dataInputAssociation id="DataAssoc_Summarise_Input">
        <bpmn:sourceRef>DataRef_IncidentReport</bpmn:sourceRef>
        <bpmn:targetRef>Task_SummariseSituation_Input_1</bpmn:targetRef>
      </bpmn:dataInputAssociation>
    </bpmn:task>
    <bpmn:task id="Task_VerifyWithUnits" name="与相关单位核实情况">
      <bpmn:incoming>Flow_Summarise_Verify</bpmn:incoming>
      <bpmn:outgoing>Flow_Verify_Report</bpmn:outgoing>
      <bpmn:documentation>层级：3
任务描述：与监理、建设单位及现场指挥保持通信，核对事故事实和资源需求，确保对外报告准确一致。
预案摘录：预案2.2.4(2)要求应急组织人员赶赴现场并分工协作，保持通信联络掌握真实情况。
责任主体：信息联络组
所需资源：联络清单、会议记录
任务路径：总体应急目标 → 事故信息上报启动流程 → 项目部汇总并评估险情 → 与相关单位核实情况</bpmn:documentation>
    </bpmn:task>
    <bpmn:task id="Task_ReportAuthorities" name="向主管部门同步报告">
      <bpmn:incoming>Flow_Verify_Report</bpmn:incoming>
      <bpmn:outgoing>Flow_Report_Escalate</bpmn:outgoing>
      <bpmn:documentation>层级：2
任务描述：信息联络组在项目部汇总后，按规定向交通、应急、海事等主管部门通报事故并请求指导支援。
预案摘录：预案2.2.5.1(2)强调接报后立即向项目部、公司调度室以及就近海事局或海上搜救中心报告。
责任主体：信息联络组
所需资源：报告模板、通讯录
任务路径：总体应急目标 → 事故信息上报启动流程 → 向主管部门同步报告</bpmn:documentation>
    </bpmn:task>
    <bpmn:task id="Task_EscalateAuthorities" name="按要求逐级通报">
      <bpmn:incoming>Flow_Report_Escalate</bpmn:incoming>
      <bpmn:outgoing>Flow_Escalate_Initiate</bpmn:outgoing>
      <bpmn:documentation>层级：3
任务描述：依照政府应急体系逐级汇报事故性质、发展态势与所需支援，保持与外部主管部门的同步沟通。
预案摘录：预案2.2.5.1(2)提出需向项目部、公司及海事部门报告，必要时联系海上搜救中心协助处置。
责任主体：信息联络组
所需资源：报送系统、联络记录
任务路径：总体应急目标 → 事故信息上报启动流程 → 向主管部门同步报告 → 按要求逐级通报</bpmn:documentation>
    </bpmn:task>
    <bpmn:task id="Task_InitiateResponse" name="启动项目应急响应程序">
      <bpmn:incoming>Flow_Escalate_Initiate</bpmn:incoming>
      <bpmn:outgoing>Flow_Initiate_Assess</bpmn:outgoing>
      <bpmn:documentation>层级：1
任务描述：项目部应急领导小组根据险情研判启动应急预案，组织各小组到位执行处置任务。
预案摘录：预案2.2.4说明项目部应急救援领导小组接到报告后立即评估险情并决定响应等级、启动预案。
责任主体：项目部应急领导小组
所需资源：应急车辆、通信装备、调度平台
任务路径：总体应急目标 → 启动项目应急响应程序</bpmn:documentation>
    </bpmn:task>
    <bpmn:task id="Task_AssessResponseLevel" name="研判并确定响应等级">
      <bpmn:incoming>Flow_Initiate_Assess</bpmn:incoming>
      <bpmn:outgoing>Flow_Assess_Gateway</bpmn:outgoing>
      <bpmn:documentation>层级：2
任务描述：综合事故规模与影响范围，判定启动项目内部Ⅱ级响应或升级为需要社会力量参与的Ⅰ级响应。
预案摘录：预案2.2.4指出领导小组需根据评估结果确定响应等级并组织执行。
责任主体：项目部应急领导小组
所需资源：响应分级标准、决策信息
任务路径：总体应急目标 → 启动项目应急响应程序 → 研判并确定响应等级</bpmn:documentation>
    </bpmn:task>
    <bpmn:exclusiveGateway id="Gateway_ResponseLevel" name="响应等级判定">
      <bpmn:incoming>Flow_Assess_Gateway</bpmn:incoming>
      <bpmn:outgoing>Flow_Response_Internal</bpmn:outgoing>
      <bpmn:outgoing>Flow_Response_External</bpmn:outgoing>
      <bpmn:documentation>根据核实后的险情，判断是否需要升级为社会救援级别。</bpmn:documentation>
    </bpmn:exclusiveGateway>
    <bpmn:task id="Task_InternalResponse" name="组织项目内部自救处置">
      <bpmn:incoming>Flow_Response_Internal</bpmn:incoming>
      <bpmn:outgoing>Flow_Internal_Merge</bpmn:outgoing>
      <bpmn:documentation>层级：3
任务描述：当事故可在项目范围内控制时，调集项目资源开展自救抢险、医疗救护与现场警戒。
预案摘录：预案2.2.4提到现场处置小组先期处置并向项目部汇报，项目部可组织内部力量控制险情。
责任主体：项目部应急领导小组
所需资源：项目部应急资源、人员清单
任务路径：总体应急目标 → 启动项目应急响应程序 → 研判并确定响应等级 → 组织项目内部自救处置</bpmn:documentation>
    </bpmn:task>
    <bpmn:task id="Task_RequestExternalSupport" name="协调外部救援力量介入">
      <bpmn:incoming>Flow_Response_External</bpmn:incoming>
      <bpmn:outgoing>Flow_External_Merge</bpmn:outgoing>
      <bpmn:documentation>层级：3
任务描述：当险情超出项目能力时，请求政府、海事或搜救中心等外部专业力量增援，确保人命与船舶安全。
预案摘录：预案2.2.5.1(2)、(12)强调必要时向海事局、搜救中心报告并请求第三方援助。
责任主体：项目部应急领导小组
所需资源：社会救援资源、联络渠道
任务路径：总体应急目标 → 启动项目应急响应程序 → 研判并确定响应等级 → 协调外部救援力量介入</bpmn:documentation>
    </bpmn:task>
    <bpmn:exclusiveGateway id="Gateway_ResponseMerge" name="响应路径汇合">
      <bpmn:incoming>Flow_Internal_Merge</bpmn:incoming>
      <bpmn:incoming>Flow_External_Merge</bpmn:incoming>
      <bpmn:outgoing>Flow_Merge_Define</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="Task_DefineTeamMissions" name="明确各应急小组任务">
      <bpmn:incoming>Flow_Merge_Define</bpmn:incoming>
      <bpmn:outgoing>Flow_Define_Issue</bpmn:outgoing>
      <bpmn:documentation>层级：2
任务描述：根据预案将医疗救护、工程抢险、综合协调、信息联络等小组的职责迅速细化到岗位，形成作战部署。
预案摘录：预案2.2.4(2)要求应急组织人员赶赴现场并同时安排救治、报警、封闭现场等多项任务。
责任主体：项目部领导、各应急小组组长
所需资源：任务分工表、调度命令
任务路径：总体应急目标 → 启动项目应急响应程序 → 明确各应急小组任务</bpmn:documentation>
    </bpmn:task>
    <bpmn:task id="Task_IssueOrders" name="向各小组下达现场处置指令">
      <bpmn:incoming>Flow_Define_Issue</bpmn:incoming>
      <bpmn:outgoing>Flow_Issue_Onsite</bpmn:outgoing>
      <bpmn:documentation>层级：3
任务描述：项目部领导根据现场研判向各小组发布抢险、救护、封控等指令，确保行动同步推进。
预案摘录：预案2.2.4(2)描述接报后需要同时安排救治、报警、封闭现场等任务，体现指挥统一调度。
责任主体：项目部领导
所需资源：指挥终端、调度命令
任务路径：总体应急目标 → 启动项目应急响应程序 → 明确各应急小组任务 → 向各小组下达现场处置指令</bpmn:documentation>
      <bpmn:ioSpecification>
        <bpmn:dataOutput id="Task_IssueOrders_Output_1" />
        <bpmn:outputSet>
          <bpmn:dataOutputRefs>Task_IssueOrders_Output_1</bpmn:dataOutputRefs>
        </bpmn:outputSet>
      </bpmn:ioSpecification>
      <bpmn:dataOutputAssociation id="DataAssoc_IssueOrders_Output">
        <bpmn:sourceRef>Task_IssueOrders_Output_1</bpmn:sourceRef>
        <bpmn:targetRef>DataRef_ResponseOrders</bpmn:targetRef>
      </bpmn:dataOutputAssociation>
    </bpmn:task>
    <bpmn:task id="Task_OnsiteOperations" name="组织现场抢险救援行动">
      <bpmn:incoming>Flow_Issue_Onsite</bpmn:incoming>
      <bpmn:outgoing>Flow_Onsite_Split</bpmn:outgoing>
      <bpmn:documentation>层级：1
任务描述：按照专项预案开展医疗救护、封闭事故区、调动设备等行动，控制险情发展。
预案摘录：预案2.2.4(2)-(3)明确现场需同步组织救治、求援、封闭现场和调动设备抢救，尽量降低损失。
责任主体：现场处置小组、医疗救护组、工程抢险组、综合协调组
所需资源：抢险设备、医疗物资、交通管制设施、通信装备
任务路径：总体应急目标 → 组织现场抢险救援行动</bpmn:documentation>
    </bpmn:task>
    <bpmn:parallelGateway id="Gateway_ParallelSplit" name="指令同步各小组">
      <bpmn:incoming>Flow_Onsite_Split</bpmn:incoming>
      <bpmn:outgoing>Flow_Split_MedicalPlan</bpmn:outgoing>
      <bpmn:outgoing>Flow_Split_EngineeringDeploy</bpmn:outgoing>
      <bpmn:outgoing>Flow_Split_Coordination</bpmn:outgoing>
      <bpmn:outgoing>Flow_Split_Communications</bpmn:outgoing>
    </bpmn:parallelGateway>
    <bpmn:task id="Task_MedicalPlan" name="安排受伤人员救治流程">
      <bpmn:incoming>Flow_Split_MedicalPlan</bpmn:incoming>
      <bpmn:outgoing>Flow_MedicalPlan_Aid</bpmn:outgoing>
      <bpmn:documentation>层级：2
任务描述：根据伤情制定紧急救治方案，联系120并准备接应医护人员，保障伤员及时救治。
预案摘录：预案2.2.4(2)①-②要求根据受伤程度采取紧急救治、向120求救并派人引导救护车到场。
责任主体：医疗救护组
所需资源：急救药品、担架、救护车
任务路径：总体应急目标 → 组织现场抢险救援行动 → 安排受伤人员救治流程</bpmn:documentation>
      <bpmn:ioSpecification>
        <bpmn:dataInput id="Task_MedicalPlan_Input_1" />
        <bpmn:inputSet>
          <bpmn:dataInputRefs>Task_MedicalPlan_Input_1</bpmn:dataInputRefs>
        </bpmn:inputSet>
      </bpmn:ioSpecification>
      <bpmn:dataInputAssociation id="DataAssoc_MedicalPlan_Input">
        <bpmn:sourceRef>DataRef_ResponseOrders</bpmn:sourceRef>
        <bpmn:targetRef>Task_MedicalPlan_Input_1</bpmn:targetRef>
      </bpmn:dataInputAssociation>
    </bpmn:task>
    <bpmn:task id="Task_MedicalAid" name="实施现场紧急救护">
      <bpmn:incoming>Flow_MedicalPlan_Aid</bpmn:incoming>
      <bpmn:outgoing>Flow_MedicalAid_Transfer</bpmn:outgoing>
      <bpmn:documentation>层级：3
任务描述：医护与现场救援人员在专业救援抵达前持续开展包扎、止血、心肺复苏等急救，保障伤员生命体征稳定。
预案摘录：预案2.2.4(2)②指出医务人员未接替救治前现场人员应及时组织抢救。
责任主体：医疗救护组
所需资源：急救包、心肺复苏设备
任务路径：总体应急目标 → 组织现场抢险救援行动 → 安排受伤人员救治流程 → 实施现场紧急救护</bpmn:documentation>
      <bpmn:ioSpecification>
        <bpmn:dataOutput id="Task_MedicalAid_Output_1" />
        <bpmn:outputSet>
          <bpmn:dataOutputRefs>Task_MedicalAid_Output_1</bpmn:dataOutputRefs>
        </bpmn:outputSet>
      </bpmn:ioSpecification>
      <bpmn:dataOutputAssociation id="DataAssoc_MedicalAid_Output">
        <bpmn:sourceRef>Task_MedicalAid_Output_1</bpmn:sourceRef>
        <bpmn:targetRef>DataRef_MedicalRecord</bpmn:targetRef>
      </bpmn:dataOutputAssociation>
    </bpmn:task>
    <bpmn:task id="Task_MedicalTransfer" name="联系120并护送转运">
      <bpmn:incoming>Flow_MedicalAid_Transfer</bpmn:incoming>
      <bpmn:outgoing>Flow_Medical_Join</bpmn:outgoing>
      <bpmn:documentation>层级：3
任务描述：拨打120抢救中心并派员在交通节点引导救护车，协助医务人员将伤员安全转运医院。
预案摘录：预案2.2.4(2)②要求向120求救并派人在交叉路口指引救护车尽快到达。
责任主体：医疗救护组
所需资源：通讯设备、转运路线图
任务路径：总体应急目标 → 组织现场抢险救援行动 → 安排受伤人员救治流程 → 联系120并护送转运</bpmn:documentation>
    </bpmn:task>
    <bpmn:task id="Task_EngineeringDeploy" name="调配装备进行工程抢险">
      <bpmn:incoming>Flow_Split_EngineeringDeploy</bpmn:incoming>
      <bpmn:outgoing>Flow_Engineering_Block</bpmn:outgoing>
      <bpmn:documentation>层级：2
任务描述：组织抢险力量抢救事故设备和受困人员，采取排水、堵漏、加固等措施遏制险情扩散。
预案摘录：预案2.2.4(3)强调组织人员调动设备抢救事故设备和人员；预案2.2.5.1(6)-(7)要求采取排水、堵漏等应对措施。
责任主体：工程抢险组
所需资源：排水泵、堵漏工具、吊装设备
任务路径：总体应急目标 → 组织现场抢险救援行动 → 调配装备进行工程抢险</bpmn:documentation>
      <bpmn:ioSpecification>
        <bpmn:dataInput id="Task_EngineeringDeploy_Input_1" />
        <bpmn:inputSet>
          <bpmn:dataInputRefs>Task_EngineeringDeploy_Input_1</bpmn:dataInputRefs>
        </bpmn:inputSet>
      </bpmn:ioSpecification>
      <bpmn:dataInputAssociation id="DataAssoc_EngineeringPlan_Input">
        <bpmn:sourceRef>DataRef_ResponseOrders</bpmn:sourceRef>
        <bpmn:targetRef>Task_EngineeringDeploy_Input_1</bpmn:targetRef>
      </bpmn:dataInputAssociation>
    </bpmn:task>
    <bpmn:task id="Task_BlockArea" name="封锁现场设置警戒">
      <bpmn:incoming>Flow_Engineering_Block</bpmn:incoming>
      <bpmn:outgoing>Flow_Block_Control</bpmn:outgoing>
      <bpmn:documentation>层级：3
任务描述：在事故周边设置警戒带和警示标志，阻止无关人员进入，维护救援秩序。
预案摘录：预案2.2.4(2)③要求封闭事故现场并设置警示标志，禁止无关人员进入。
责任主体：工程抢险组、综合协调组
所需资源：警戒带、警示标志
任务路径：总体应急目标 → 组织现场抢险救援行动 → 调配装备进行工程抢险 → 封锁现场设置警戒</bpmn:documentation>
    </bpmn:task>
    <bpmn:task id="Task_EngineeringControl" name="排水堵漏稳定结构">
      <bpmn:incoming>Flow_Block_Control</bpmn:incoming>
      <bpmn:outgoing>Flow_Engineering_Join</bpmn:outgoing>
      <bpmn:documentation>层级：3
任务描述：根据破损情况实施排水、堵漏、加固及必要时抢滩坐浅等措施，稳定船体和施工设备。
预案摘录：预案2.2.5.1(6)-(7)和2.2.5.3(5)-(11)提出通过排水、堵漏、加固及抢滩等手段控制险情发展。
责任主体：工程抢险组
所需资源：抢险设备、加固材料
任务路径：总体应急目标 → 组织现场抢险救援行动 → 调配装备进行工程抢险 → 排水堵漏稳定结构</bpmn:documentation>
      <bpmn:ioSpecification>
        <bpmn:dataOutput id="Task_EngineeringControl_Output_1" />
        <bpmn:outputSet>
          <bpmn:dataOutputRefs>Task_EngineeringControl_Output_1</bpmn:dataOutputRefs>
        </bpmn:outputSet>
      </bpmn:ioSpecification>
      <bpmn:dataOutputAssociation id="DataAssoc_Engineering_Output">
        <bpmn:sourceRef>Task_EngineeringControl_Output_1</bpmn:sourceRef>
        <bpmn:targetRef>DataRef_EngineeringLog</bpmn:targetRef>
      </bpmn:dataOutputAssociation>
    </bpmn:task>
    <bpmn:task id="Task_Coordination" name="协调交通疏导与现场秩序">
      <bpmn:incoming>Flow_Split_Coordination</bpmn:incoming>
      <bpmn:outgoing>Flow_Coordination_Evacuation</bpmn:outgoing>
      <bpmn:documentation>层级：2
任务描述：综合协调组配合公安、交通等力量实施交通管制、人员疏散和现场保护，防止次生事故。
预案摘录：预案2.2.4(2)③提示要封闭现场、设置警示并禁止无关人员进入，确保现场秩序。
责任主体：综合协调组
所需资源：交通管制设施、疏导方案
任务路径：总体应急目标 → 组织现场抢险救援行动 → 协调交通疏导与现场秩序</bpmn:documentation>
      <bpmn:ioSpecification>
        <bpmn:dataInput id="Task_Coordination_Input_1" />
        <bpmn:inputSet>
          <bpmn:dataInputRefs>Task_Coordination_Input_1</bpmn:dataInputRefs>
        </bpmn:inputSet>
      </bpmn:ioSpecification>
      <bpmn:dataInputAssociation id="DataAssoc_Coordination_Input">
        <bpmn:sourceRef>DataRef_ResponseOrders</bpmn:sourceRef>
        <bpmn:targetRef>Task_Coordination_Input_1</bpmn:targetRef>
      </bpmn:dataInputAssociation>
    </bpmn:task>
    <bpmn:task id="Task_Evacuation" name="组织撤离非作业人员">
      <bpmn:incoming>Flow_Coordination_Evacuation</bpmn:incoming>
      <bpmn:outgoing>Flow_Evacuation_Join</bpmn:outgoing>
      <bpmn:documentation>层级：3
任务描述：指挥无关人员撤离事故区，安排安全集合点，保障救援通道畅通。
预案摘录：预案2.2.4(2)③提出封闭现场并禁止无关人员进入，需要组织人员疏散。
责任主体：综合协调组
所需资源：疏散预案、引导人员
任务路径：总体应急目标 → 组织现场抢险救援行动 → 协调交通疏导与现场秩序 → 组织撤离非作业人员</bpmn:documentation>
    </bpmn:task>
    <bpmn:task id="Task_Communications" name="保持内外通信与信息传递">
      <bpmn:incoming>Flow_Split_Communications</bpmn:incoming>
      <bpmn:outgoing>Flow_Communications_Liaison</bpmn:outgoing>
      <bpmn:documentation>层级：2
任务描述：信息联络组同步向现场指挥、项目部和外部单位传递险情变化，确保指挥协调顺畅。
预案摘录：预案2.2.4(2)②和2.2.5.2(13)要求保持与内外部的通信联络，及时通报情况。
责任主体：信息联络组
所需资源：通信装备、联络记录
任务路径：总体应急目标 → 组织现场抢险救援行动 → 保持内外通信与信息传递</bpmn:documentation>
      <bpmn:ioSpecification>
        <bpmn:dataInput id="Task_Communications_Input_1" />
        <bpmn:inputSet>
          <bpmn:dataInputRefs>Task_Communications_Input_1</bpmn:dataInputRefs>
        </bpmn:inputSet>
      </bpmn:ioSpecification>
      <bpmn:dataInputAssociation id="DataAssoc_Communications_Input">
        <bpmn:sourceRef>DataRef_ResponseOrders</bpmn:sourceRef>
        <bpmn:targetRef>Task_Communications_Input_1</bpmn:targetRef>
      </bpmn:dataInputAssociation>
    </bpmn:task>
    <bpmn:task id="Task_ExternalLiaison" name="对接医院海事等外部单位">
      <bpmn:incoming>Flow_Communications_Liaison</bpmn:incoming>
      <bpmn:outgoing>Flow_Liaison_Join</bpmn:outgoing>
      <bpmn:documentation>层级：3
任务描述：持续联系120救援中心、海事局、搜救中心及相关政府部门，通报救援需求并协调支援力量。
预案摘录：预案2.2.4(2)②、2.2.5.1(2)和2.2.5.2(4)要求向120、海事局等外部机构报告并保持联络。
责任主体：信息联络组
所需资源：联络清单、对外通报材料
任务路径：总体应急目标 → 组织现场抢险救援行动 → 保持内外通信与信息传递 → 对接医院海事等外部单位</bpmn:documentation>
      <bpmn:ioSpecification>
        <bpmn:dataOutput id="Task_ExternalLiaison_Output_1" />
        <bpmn:outputSet>
          <bpmn:dataOutputRefs>Task_ExternalLiaison_Output_1</bpmn:dataOutputRefs>
        </bpmn:outputSet>
      </bpmn:ioSpecification>
      <bpmn:dataOutputAssociation id="DataAssoc_StatusUpdates_Output">
        <bpmn:sourceRef>Task_ExternalLiaison_Output_1</bpmn:sourceRef>
        <bpmn:targetRef>DataRef_StatusUpdates</bpmn:targetRef>
      </bpmn:dataOutputAssociation>
    </bpmn:task>
    <bpmn:parallelGateway id="Gateway_ParallelJoin" name="现场行动反馈">
      <bpmn:incoming>Flow_Medical_Join</bpmn:incoming>
      <bpmn:incoming>Flow_Engineering_Join</bpmn:incoming>
      <bpmn:incoming>Flow_Evacuation_Join</bpmn:incoming>
      <bpmn:incoming>Flow_Liaison_Join</bpmn:incoming>
      <bpmn:outgoing>Flow_Join_Recovery</bpmn:outgoing>
    </bpmn:parallelGateway>
    <bpmn:task id="Task_RecoveryTransition" name="进入善后与恢复阶段">
      <bpmn:incoming>Flow_Join_Recovery</bpmn:incoming>
      <bpmn:outgoing>Flow_Recovery_Split</bpmn:outgoing>
      <bpmn:documentation>层级：1
任务描述：险情受控后转入善后、调查和总结工作，确保事故响应形成闭环管理。
预案摘录：预案2.2.4(4)指出在伤员救护可靠、事故得到控制且资源到位后，应急救援行动结束并进入后续处置。
责任主体：善后处置组、技术支持组、项目部应急领导小组
所需资源：善后资金、法律支持、档案资料
任务路径：总体应急目标 → 进入善后与恢复阶段</bpmn:documentation>
    </bpmn:task>
    <bpmn:parallelGateway id="Gateway_RecoverySplit" name="恢复任务分流">
      <bpmn:incoming>Flow_Recovery_Split</bpmn:incoming>
      <bpmn:outgoing>Flow_RecoverySplit_Aftercare</bpmn:outgoing>
      <bpmn:outgoing>Flow_RecoverySplit_Investigation</bpmn:outgoing>
    </bpmn:parallelGateway>
    <bpmn:task id="Task_Aftercare" name="落实安置补偿和后勤保障">
      <bpmn:incoming>Flow_RecoverySplit_Aftercare</bpmn:incoming>
      <bpmn:outgoing>Flow_Aftercare_Psych</bpmn:outgoing>
      <bpmn:documentation>层级：2
任务描述：组织受影响人员的安置、补偿及心理支持，恢复生产生活秩序并调配保障资源。
预案摘录：预案2.2.4(4)提示在事故控制并资源落实后转入善后处置，确保人员得到妥善安置。
责任主体：善后处置组
所需资源：补偿资金、安置方案、心理服务资源
任务路径：总体应急目标 → 进入善后与恢复阶段 → 落实安置补偿和后勤保障</bpmn:documentation>
    </bpmn:task>
    <bpmn:task id="Task_PsychologicalSupport" name="提供心理慰藉与家属沟通">
      <bpmn:incoming>Flow_Aftercare_Psych</bpmn:incoming>
      <bpmn:outgoing>Flow_Psych_RecoveryMerge</bpmn:outgoing>
      <bpmn:documentation>层级：3
任务描述：善后处置组安排心理疏导和家属沟通，帮助伤亡人员及家属稳定情绪。
预案摘录：预案2.2.4(4)强调救援结束后进入善后阶段，需要保障人员获得必要支持。
责任主体：善后处置组
所需资源：心理辅导人员、慰问材料
任务路径：总体应急目标 → 进入善后与恢复阶段 → 落实安置补偿和后勤保障 → 提供心理慰藉与家属沟通</bpmn:documentation>
    </bpmn:task>
    <bpmn:task id="Task_Investigation" name="组织事故调查与责任认定">
      <bpmn:incoming>Flow_RecoverySplit_Investigation</bpmn:incoming>
      <bpmn:outgoing>Flow_Investigation_Collect</bpmn:outgoing>
      <bpmn:documentation>层级：2
任务描述：联合技术支持组和相关机构查明事故原因、责任主体及改进措施，形成调查结论。
预案摘录：预案2.2.5.1(3)-(4)、(9)-(11)要求查明破损情况、保存记录并向主管机关报告，为事故调查提供依据。
责任主体：技术支持组、外部机构
所需资源：调查工具、法律支持
任务路径：总体应急目标 → 进入善后与恢复阶段 → 组织事故调查与责任认定</bpmn:documentation>
    </bpmn:task>
    <bpmn:task id="Task_CollectEvidence" name="收集日志影像等调查资料">
      <bpmn:incoming>Flow_Investigation_Collect</bpmn:incoming>
      <bpmn:outgoing>Flow_Collect_RecoveryMerge</bpmn:outgoing>
      <bpmn:documentation>层级：3
任务描述：系统整理航海日志、轮机日志、照片和监测记录，为事故调查和责任认定提供证据。
预案摘录：预案2.2.5.1(9)-(10)强调保存被碰撞通知书、海图、损坏草图、照片及各类日志记录。
责任主体：技术支持组
所需资源：航海日志、影像资料、取证设备
任务路径：总体应急目标 → 进入善后与恢复阶段 → 组织事故调查与责任认定 → 收集日志影像等调查资料</bpmn:documentation>
    </bpmn:task>
    <bpmn:parallelGateway id="Gateway_RecoveryMerge" name="恢复任务汇合">
      <bpmn:incoming>Flow_Psych_RecoveryMerge</bpmn:incoming>
      <bpmn:incoming>Flow_Collect_RecoveryMerge</bpmn:incoming>
      <bpmn:outgoing>Flow_RecoveryMerge_Evaluate</bpmn:outgoing>
    </bpmn:parallelGateway>
    <bpmn:task id="Task_EvaluateResponse" name="评估响应成效提出改进">
      <bpmn:incoming>Flow_RecoveryMerge_Evaluate</bpmn:incoming>
      <bpmn:outgoing>Flow_Evaluate_FinalReport</bpmn:outgoing>
      <bpmn:documentation>层级：2
任务描述：对应急行动的组织、协同与资源保障进行复盘，总结经验教训并提出改进措施。
预案摘录：预案2.2.4(4)要求在行动结束后落实人员物资并开展后续处置，为总结评估提供条件。
责任主体：项目部应急领导小组
所需资源：评估模型、会议纪要
任务路径：总体应急目标 → 进入善后与恢复阶段 → 评估响应成效提出改进</bpmn:documentation>
    </bpmn:task>
    <bpmn:task id="Task_FinalReport" name="形成总结评估书面报告">
      <bpmn:incoming>Flow_Evaluate_FinalReport</bpmn:incoming>
      <bpmn:outgoing>Flow_FinalReport_End</bpmn:outgoing>
      <bpmn:documentation>层级：3
任务描述：项目部应急领导小组编写事故应急处置报告，记录过程、成效与改进建议，归档入库。
预案摘录：预案2.2.5.1(10)-(11)提出要做好详细记录并向主管机关报告，为形成总结报告提供依据。
责任主体：项目部应急领导小组
所需资源：总结报告模板、档案系统
任务路径：总体应急目标 → 进入善后与恢复阶段 → 评估响应成效提出改进 → 形成总结评估书面报告</bpmn:documentation>
      <bpmn:ioSpecification>
        <bpmn:dataInput id="Task_FinalReport_Input_1" />
        <bpmn:dataInput id="Task_FinalReport_Input_2" />
        <bpmn:dataInput id="Task_FinalReport_Input_3" />
        <bpmn:dataInput id="Task_FinalReport_Input_4" />
        <bpmn:dataOutput id="Task_FinalReport_Output_1" />
        <bpmn:inputSet>
          <bpmn:dataInputRefs>Task_FinalReport_Input_1</bpmn:dataInputRefs>
          <bpmn:dataInputRefs>Task_FinalReport_Input_2</bpmn:dataInputRefs>
          <bpmn:dataInputRefs>Task_FinalReport_Input_3</bpmn:dataInputRefs>
          <bpmn:dataInputRefs>Task_FinalReport_Input_4</bpmn:dataInputRefs>
        </bpmn:inputSet>
        <bpmn:outputSet>
          <bpmn:dataOutputRefs>Task_FinalReport_Output_1</bpmn:dataOutputRefs>
        </bpmn:outputSet>
      </bpmn:ioSpecification>
      <bpmn:dataInputAssociation id="DataAssoc_Final_Input_Response">
        <bpmn:sourceRef>DataRef_ResponseOrders</bpmn:sourceRef>
        <bpmn:targetRef>Task_FinalReport_Input_1</bpmn:targetRef>
      </bpmn:dataInputAssociation>
      <bpmn:dataInputAssociation id="DataAssoc_Final_Input_Medical">
        <bpmn:sourceRef>DataRef_MedicalRecord</bpmn:sourceRef>
        <bpmn:targetRef>Task_FinalReport_Input_2</bpmn:targetRef>
      </bpmn:dataInputAssociation>
      <bpmn:dataInputAssociation id="DataAssoc_Final_Input_Engineering">
        <bpmn:sourceRef>DataRef_EngineeringLog</bpmn:sourceRef>
        <bpmn:targetRef>Task_FinalReport_Input_3</bpmn:targetRef>
      </bpmn:dataInputAssociation>
      <bpmn:dataInputAssociation id="DataAssoc_Final_Input_Status">
        <bpmn:sourceRef>DataRef_StatusUpdates</bpmn:sourceRef>
        <bpmn:targetRef>Task_FinalReport_Input_4</bpmn:targetRef>
      </bpmn:dataInputAssociation>
      <bpmn:dataOutputAssociation id="DataAssoc_Final_Output">
        <bpmn:sourceRef>Task_FinalReport_Output_1</bpmn:sourceRef>
        <bpmn:targetRef>DataRef_FinalReport</bpmn:targetRef>
      </bpmn:dataOutputAssociation>
    </bpmn:task>
    <bpmn:endEvent id="EndEvent_ResponseComplete" name="响应结束">
      <bpmn:incoming>Flow_FinalReport_End</bpmn:incoming>
    </bpmn:endEvent>
